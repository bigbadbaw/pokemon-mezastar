{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm test *)",
      "Bash(pnpm tsc --noEmit)",
      "Bash(pnpm prettier *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Read(src/**)",
      "Read(public/**)",
      "Read(CLAUDE.md)",
      "Read(package.json)",
      "Read(tsconfig.json)",
      "Read(tailwind.config.*)",
      "Read(next.config.*)",
      "Write(src/**)",
      "Write(public/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE\"; ext=\"${file##*.}\"; if [ \"$ext\" = \"ts\" ] || [ \"$ext\" = \"tsx\" ]; then npx prettier --write \"$file\" 2>/dev/null; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCommit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint && pnpm tsc --noEmit",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
