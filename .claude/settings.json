{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(src/**)",
      "Write(public/**)",
      "Write(package.json)",
      "Write(tsconfig.json)",
      "Write(tailwind.config.*)",
      "Write(next.config.*)",
      "Write(postcss.config.*)",
      "Write(.eslintrc.*)",
      "Write(.prettierrc*)",
      "Write(manifest.json)",
      "Write(CLAUDE.md)",
      "Write(.claude/**)",
      "Write(.claudeignore)",
      "Write(.gitignore)",
      "Write(README.md)",
      "Write(vitest.config.*)",
      "Write(components.json)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)"
    ]
  },
  "hooks": {
    "PreCommit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint && pnpm tsc --noEmit",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}